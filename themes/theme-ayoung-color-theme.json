{
    "name": "theme-ayoung",
    "type": "dark",
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#93c5fd",
        "variable.readonly": "#818cf8",
        "variable.constant": "#818cf8",
        "variable.defaultLibrary": "#818cf8",
        "enumMember": "#818cf8",
        "parameter": "#93c5fd",
        "property": "#93c5fd",
        "property.readonly": "#818cf8",
        "function": "#7ecec8",
        "method": "#7ecec8",
        "class": "#5eead4",
        "interface": "#5eead4",
        "type": "#5eead4",
        "typeParameter": "#5eead4",
        "namespace": "#5eead4",
        "enum": "#5eead4",
        "struct": "#5eead4",
        "keyword": "#d4a5b5",
        "modifier": "#d4a5b5",
        "string": "#fed7aa",
        "number": "#d0d0da",
        "comment": "#6b6b82",
        "operator": "#a0a0b4",
        "macro": "#5eead4",
        "decorator": "#7ecec8"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": "comment, punctuation.definition.comment",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#6b6b82"
            }
        },
        {
            "name": "Variables",
            "scope": "variable",
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "Language variables (this, self, super)",
            "scope": "variable.language",
            "settings": {
                "foreground": "#818cf8",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Constants",
            "scope": "variable.other.constant",
            "settings": {
                "foreground": "#818cf8"
            }
        },
        {
            "name": "Keywords",
            "scope": "keyword",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "new keyword",
            "scope": ["keyword.operator.new", "keyword.operator.new.js", "keyword.operator.new.ts"],
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "Keyword Control",
            "scope": "keyword.control",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "Storage (const, let, var, function, class...)",
            "scope": "storage",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "Operators",
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#a0a0b4"
            }
        },
        {
            "name": "Punctuation",
            "scope": "punctuation",
            "settings": {
                "foreground": "#a0a0b4"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "meta.require",
                "support.function.any-method",
                "variable.function"
            ],
            "settings": {
                "foreground": "#7ecec8"
            }
        },
        {
            "name": "Support functions",
            "scope": "support.function",
            "settings": {
                "foreground": "#7ecec8"
            }
        },
        {
            "name": "Classes",
            "scope": [
                "support.class",
                "entity.name.type.class",
                "entity.name.class",
                "entity.name.type.namespace",
                "entity.name.namespace"
            ],
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Type Names",
            "scope": "entity.name.type",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Inherited Class",
            "scope": "entity.other.inherited-class",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Strings",
            "scope": "string",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Escape characters and placeholders",
            "scope": [
                "constant.character.escape",
                "constant.character.format.placeholder.other.python"
            ],
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Regular Expressions",
            "scope": "string.regexp",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Constants",
            "scope": "constant",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Numbers",
            "scope": "constant.numeric",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Tags",
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#818cf8"
            }
        },
        {
            "name": "Attributes",
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "Object properties / readwrite variables",
            "scope": "variable.other.readwrite, meta.object-literal.key, support.variable.property",
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "Support type property names (CSS, JSON)",
            "scope": "support.type.property-name",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "JSON property names",
            "scope": "support.type.property-name.json",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "JSON string values",
            "scope": [
                "source.json meta.structure.dictionary.json > value.json > string.quoted.json",
                "source.json meta.structure.array.json > value.json > string.quoted.json"
            ],
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "JSON boolean/null",
            "scope": [
                "source.json meta.structure.dictionary.json > constant.language.json",
                "source.json meta.structure.array.json > constant.language.json"
            ],
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "String interpolation punctuation",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#a0a0b4"
            }
        },
        {
            "name": "Template expression reset",
            "scope": "meta.template.expression",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid.illegal",
            "settings": {
                "foreground": "#f87171"
            }
        },
        {
            "name": "Diff - Inserted",
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Diff - Deleted",
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#f87171"
            }
        },
        {
            "name": "Diff - Changed",
            "scope": "markup.changed",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "URL",
            "scope": ["*url*", "*link*", "*uri*"],
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markdown - H1",
            "scope": ["heading.1.markdown entity.name.section.markdown", "heading.1.markdown"],
            "settings": {
                "foreground": "#0e7490",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown - H2",
            "scope": ["heading.2.markdown entity.name.section.markdown", "heading.2.markdown"],
            "settings": {
                "foreground": "#0891b2",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown - H3",
            "scope": ["heading.3.markdown entity.name.section.markdown", "heading.3.markdown"],
            "settings": {
                "foreground": "#06b6d4"
            }
        },
        {
            "name": "Markdown - H4",
            "scope": ["heading.4.markdown entity.name.section.markdown", "heading.4.markdown"],
            "settings": {
                "foreground": "#67e8f9"
            }
        },
        {
            "name": "Markdown - H5",
            "scope": ["heading.5.markdown entity.name.section.markdown", "heading.5.markdown"],
            "settings": {
                "foreground": "#a5f3fc"
            }
        },
        {
            "name": "Markdown - H6",
            "scope": ["heading.6.markdown entity.name.section.markdown", "heading.6.markdown"],
            "settings": {
                "foreground": "#cffafe"
            }
        },
        {
            "name": "Markdown - Heading fallback",
            "scope": [
                "markup.heading.markdown",
                "markup.heading",
                "entity.name.section.markdown",
                "punctuation.definition.heading.markdown"
            ],
            "settings": {
                "foreground": "#06b6d4"
            }
        },
        {
            "name": "Markdown - Bold",
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Markdown - Italic",
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "Markdown - Inline code",
            "scope": "markup.inline.raw.markdown, markup.inline.raw.string.markdown",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Markdown - Blockquote",
            "scope": "markup.quote.markdown",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#6b6b82"
            }
        },
        {
            "name": "Markdown - Link title",
            "scope": "string.other.link.title.markdown, string.other.link.description.markdown",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "Markdown - Link URL",
            "scope": "markup.underline.link.markdown, markup.underline.link.image.markdown",
            "settings": {
                "fontStyle": "underline",
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "Markdown - List punctuation",
            "scope": [
                "punctuation.definition.list.begin.markdown",
                "punctuation.definition.list.markdown",
                "beginning.punctuation.definition.list.markdown"
            ],
            "settings": {
                "foreground": "#a0a0b4"
            }
        },
        {
            "name": "CSS Selectors",
            "scope": "meta.selector",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "CSS property names",
            "scope": "support.type.property-name.css, support.type.vendored.property-name.css",
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "CSS property values",
            "scope": "support.constant.property-value.css, support.constant.property-value.scss",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "CSS units",
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#fed7aa"
            }
        },
        {
            "name": "SQL - DML keywords (SELECT, FROM, WHERE, JOIN, etc.)",
            "scope": [
                "keyword.other.DML.sql",
                "keyword.other.DML.II.sql",
                "keyword.other.LUW.sql",
                "keyword.other.authorization.sql",
                "keyword.other.data-integrity.sql",
                "keyword.other.DDL.create.II.sql"
            ],
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "SQL - DDL keywords (CREATE, ALTER, DROP)",
            "scope": [
                "keyword.other.create.sql",
                "keyword.other.table.sql",
                "keyword.other.cascade.sql",
                "keyword.other.sql"
            ],
            "settings": {
                "foreground": "#818cf8"
            }
        },
        {
            "name": "SQL - Constraints and modifiers (PRIMARY KEY, REFERENCES, DEFAULT, etc.)",
            "scope": ["storage.modifier.sql"],
            "settings": {
                "foreground": "#818cf8"
            }
        },
        {
            "name": "SQL - Functions (entity names in CREATE FUNCTION, stored procs)",
            "scope": ["entity.name.function.sql"],
            "settings": {
                "foreground": "#7ecec8"
            }
        },
        {
            "name": "SQL - Data types (INT, VARCHAR, BOOLEAN, TIMESTAMP, etc.)",
            "scope": ["storage.type.sql"],
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "SQL - Variables (@param) and bracketed identifiers ([TableName])",
            "scope": ["text.variable", "text.bracketed"],
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "SQL - Numeric literals",
            "scope": ["constant.numeric.sql"],
            "settings": {
                "foreground": "#d0d0da"
            }
        },
        {
            "name": "SQL - Aliases, schema names, column/table name identifiers",
            "scope": ["constant.other.database-name.sql", "constant.other.table-name.sql"],
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "Python parameters",
            "scope": "variable.parameter.function.language.python, variable.parameter.function.python",
            "settings": {
                "foreground": "#d4a5b5"
            }
        },
        {
            "name": "Python self",
            "scope": "variable.parameter.function.language.special.self.python",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#818cf8"
            }
        },
        {
            "name": "Python function call",
            "scope": "meta.function-call.generic.python",
            "settings": {
                "foreground": "#7ecec8"
            }
        },
        {
            "name": "TypeScript primitive/builtin types",
            "scope": "support.type.primitive.ts, support.type.builtin.ts, support.type.primitive.tsx, support.type.builtin.tsx",
            "settings": {
                "foreground": "#5eead4"
            }
        },
        {
            "name": "JS/TS italic attributes",
            "scope": "entity.other.attribute-name.js, entity.other.attribute-name.ts, entity.other.attribute-name.jsx, entity.other.attribute-name.tsx, variable.language.super",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "name": "token colors",
            "scope": "token.info-token",
            "settings": {
                "foreground": "#93c5fd"
            }
        },
        {
            "name": "token colors",
            "scope": "token.warn-token",
            "settings": {
                "foreground": "#fbbf24"
            }
        },
        {
            "name": "token colors",
            "scope": "token.error-token",
            "settings": {
                "foreground": "#f87171"
            }
        },
        {
            "name": "token colors",
            "scope": "token.debug-token",
            "settings": {
                "foreground": "#d4a5b5"
            }
        }
    ],
